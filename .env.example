WEBHOOK_URL=https://webhook.example.com/inbound

# Optional. When set, payloads include Mailgun-style timestamp/token/signature.
WEBHOOK_SIGNING_KEY=change-me

# Optional. When set, the decision API is called before a message is accepted
# into the webhook delivery spool. Modes: minimal, summary, full.
# WEBHOOK_DECISION_URL=https://policy.example.com/haraka/decision
# WEBHOOK_DECISION_TOKEN=change-me
WEBHOOK_DECISION_PAYLOAD_MODE=minimal

# Default reusable behavior: accept every RCPT TO delivered to this server.
ACCEPT_ALL_RECIPIENTS=true

# Optional restricted mode:
# ACCEPT_ALL_RECIPIENTS=false
# ACCEPTED_DOMAINS=example.com,example.net

# STARTTLS is opportunistic on port 25 when the cert/key are mounted and set.
# SMTP_TLS_CERT_DIR is the host directory mounted read-only into the container
# at /certs (defaults to ./certs). The *_PATH vars point at the files inside it.
# To use a real certificate, set the host directory and the paths inside it:
#   SMTP_TLS_CERT_DIR=/path/to/cert/dir
#   SMTP_TLS_CERT_PATH=/certs/fullchain.pem
#   SMTP_TLS_KEY_PATH=/certs/privkey.pem

SPOOL_DIR=/var/spool/haraka-webhook
WEBHOOK_TIMEOUT_MS=60000
RETRY_SCAN_INTERVAL_MS=5000
RETRY_INTERVAL_MS=30000
RETRY_MAX_INTERVAL_MS=3600000
